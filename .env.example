# Google Apps Script Web App URL
GAS_WEB_APP_URL=https://script.google.com/macros/s/XXXX/exec

# Shared secret. Must match Script Properties FRONTEND_API_SHARED_SECRET on GAS
FRONTEND_API_SHARED_SECRET=replace-with-long-random-secret

# ngrok auth token for public tunnel
NGROK_AUTHTOKEN=replace-with-ngrok-authtoken

# Optional: custom ngrok command (example fixed domain)
# NGROK_COMMAND=http --domain=your-domain.ngrok.app next:3333
